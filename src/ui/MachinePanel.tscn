[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/ui/MachinePanel.gd" id="1_script"]

[node name="MachinePanel" type="PanelContainer"]
custom_minimum_size = Vector2(0, 80)
script = ExtResource("1_script")

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 4
theme_override_constants/margin_right = 4
theme_override_constants/margin_top = 4
theme_override_constants/margin_bottom = 4

[node name="HBoxContainer" type="HBoxContainer" parent="MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="IconPanel" type="PanelContainer" parent="MarginContainer/HBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(52, 52)
size_flags_vertical = 4

[node name="MachineIcon" type="Label" parent="MarginContainer/HBoxContainer/IconPanel"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 28
horizontal_alignment = 1
vertical_alignment = 1

[node name="InfoVBox" type="VBoxContainer" parent="MarginContainer/HBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 2

[node name="MachineName" type="Label" parent="MarginContainer/HBoxContainer/InfoVBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 17

[node name="StatusLabel" type="Label" parent="MarginContainer/HBoxContainer/InfoVBox"]
unique_name_in_owner = true
layout_mode = 2
